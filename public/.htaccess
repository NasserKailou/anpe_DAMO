# ==============================================================================
# e-DAMO — .htaccess PUBLIC (public/)
# ==============================================================================
#
# Ce fichier gère le routage dans le dossier public/.
# Compatible : XAMPP Windows, Apache Linux, Plesk VPS, VirtualHost dédié.
#
# Scénario VPS/Plesk VirtualHost (DocumentRoot = .../public) :
#   URL : https://affectionate-lumiere.217-154-60-93.plesk.page/login
#   SCRIPT_NAME : /index.php
#   REQUEST_URI : /login
#   → BASE_PATH détecté = ''  → route = /login  ✓
#
# Scénario XAMPP sous-dossier (htdocs/anpe_DAMO/) :
#   URL : http://localhost:8085/anpe_DAMO/login
#   SCRIPT_NAME : /anpe_DAMO/public/index.php
#   → BASE_PATH détecté = /anpe_DAMO  ✓
# ==============================================================================

Options -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ── Bloquer les fichiers sensibles ─────────────────────────────────────────
    RewriteRule ^\.env$                  - [F,L]
    RewriteRule ^\.git                   - [F,L]
    RewriteRule ^composer\.(json|lock)$  - [F,L]

    # ── Bloquer les user-agents malveillants ───────────────────────────────────
    RewriteCond %{HTTP_USER_AGENT} (nikto|sqlmap|masscan|nmap) [NC]
    RewriteRule ^ - [F,L]

    # ── Laisser passer les fichiers et dossiers existants (CSS, JS, images…) ───
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ── Tout le reste → front-controller ──────────────────────────────────────
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# ── Types MIME (CRITIQUE pour que Bootstrap Icons et fonts fonctionnent) ──────
<IfModule mod_mime.c>
    AddType font/woff2        .woff2
    AddType font/woff         .woff
    AddType font/ttf          .ttf
    AddType image/svg+xml     .svg
    AddType text/css          .css
    AddType application/javascript .js
    AddType application/json  .json
</IfModule>

# ── En-têtes de sécurité (compatibles Plesk — sans directives problématiques) ─
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options  "nosniff"
    Header always set X-Frame-Options         "SAMEORIGIN"
    Header always set Referrer-Policy         "strict-origin-when-cross-origin"
    # Autoriser le chargement des polices Bootstrap depuis le même domaine
    Header always set Access-Control-Allow-Origin "*" env=IS_FONT
</IfModule>

# ── Compression GZIP ────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json font/woff2
</IfModule>

# ── Cache navigateur pour les assets statiques ──────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 30 days"
    ExpiresByType application/javascript    "access plus 30 days"
    ExpiresByType image/png                 "access plus 30 days"
    ExpiresByType image/jpeg                "access plus 30 days"
    ExpiresByType image/gif                 "access plus 30 days"
    ExpiresByType image/svg+xml             "access plus 30 days"
    ExpiresByType image/x-icon              "access plus 30 days"
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType font/ttf                  "access plus 1 year"
</IfModule>
