Options -Indexes
ServerSignature Off

RewriteEngine On

# ─────────────────────────────────────────────────────────────
# IMPORTANT : Choisir la RewriteBase selon votre installation
#
#   CAS 1 – sous-dossier XAMPP (htdocs/anpe_DAMO/)
#            URL : http://localhost:8085/anpe_DAMO/login
RewriteBase /anpe_DAMO/
#
#   CAS 2 – VirtualHost dédié (DocumentRoot = .../anpe_DAMO/public)
#            URL : http://localhost:8085/login
#RewriteBase /
# ─────────────────────────────────────────────────────────────

# Bloquer les fichiers sensibles
RewriteRule ^\.env$                  - [F,L]
RewriteRule ^\.git                   - [F,L]
RewriteRule ^composer\.(json|lock)$  - [F,L]

# Laisser passer les fichiers et dossiers qui existent vraiment (assets CSS/JS/img)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Tout le reste → index.php (front controller)
RewriteRule ^ index.php [QSA,L]

# ── En-têtes de sécurité ─────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options  "nosniff"
    Header always set X-Frame-Options         "SAMEORIGIN"
    Header always set X-XSS-Protection        "1; mode=block"
    Header always set Referrer-Policy         "strict-origin-when-cross-origin"
</IfModule>

# ── GZIP ─────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json
</IfModule>

# ── Cache assets statiques ───────────────────────────────────
<FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|woff|woff2|ttf|svg)$">
    <IfModule mod_headers.c>
        Header set Cache-Control "max-age=2592000, public"
    </IfModule>
</FilesMatch>
