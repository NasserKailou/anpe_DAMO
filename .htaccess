# ==============================================================================
# e-DAMO — .htaccess RACINE
# ==============================================================================
#
# CAS 1 — XAMPP sous-dossier (htdocs/anpe_DAMO/)
#   Ce fichier redirige vers public/ pour les requêtes applicatives.
#   Les assets (CSS, JS, images) dans public/assets/ passent directement.
#
# CAS 2 — VPS/Plesk VirtualHost (DocumentRoot = .../public/)
#   Ce fichier est dans le dossier parent du DocumentRoot → il n'est PAS
#   lu par Apache pour les requêtes web normales. Laissez-le tel quel.
# ==============================================================================

Options -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ── 0. Ne pas traiter si on est déjà dans public/ ─────────────────────────
    RewriteCond %{REQUEST_URI} ^/[^/]+/public/ [NC]
    RewriteRule ^ - [L]

    # ── 1. Laisser passer les fichiers physiques (assets, uploads…) ────────────
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ── 2. Tout le reste → public/index.php ────────────────────────────────────
    RewriteRule ^(.*)$ public/index.php [QSA,L]
</IfModule>

# ── Bloquer l'accès aux fichiers sensibles ──────────────────────────────────
<FilesMatch "^(\.env|\.env\.example|composer\.(json|lock)|\.git)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
